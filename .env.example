# ===== Application =====
APP_ENV=production
FLASK_SECRET_KEY=change-me-in-production-please
JWT_SECRET_KEY=change-me-in-production-jwt-secret

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=cotask_root_pw
MYSQL_DATABASE=cotask
MYSQL_USER=cotask
MYSQL_PASSWORD=cotask_pw
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== MinIO =====
MINIO_ROOT_USER=cotask_minio
MINIO_ROOT_PASSWORD=cotask_minio_pw
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET=cotask-files
MINIO_SECURE=false

# ===== AI =====
# Pick one provider; failures fall back via AI_PROVIDER_FALLBACK (comma-separated)
AI_PROVIDER=deepseek
AI_PROVIDER_FALLBACK=openai,anthropic,dashscope
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DASHSCOPE_API_KEY=
AI_MODEL_ANTHROPIC=claude-sonnet-4-6
AI_MODEL_OPENAI=gpt-4o-mini
AI_MODEL_DEEPSEEK=deepseek-v4-flash
AI_MODEL_DASHSCOPE=qwen-max
AI_REQUEST_TIMEOUT=60

# ===== SMS / Email =====
# stub: dev mode — code stored in Redis and logged on the server
# aliyun: Aliyun PNVS SMS auth (SendSmsVerifyCode / CheckSmsVerifyCode)
SMS_PROVIDER=stub
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_AUTH_SIGN_NAME=速通互联验证平台
SMS_AUTH_TEMPLATE_CODE=100001
SMS_COUNTRY_CODE=86
SMS_CODE_LENGTH=4
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@cotask.local

# ===== WeChat OAuth (v1.1) =====
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ===== Frontend (build-time) =====
VITE_API_BASE=/api
VITE_WS_BASE=/ws
